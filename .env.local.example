# ─────────────────────────────────────────────────────────────────────────────
# Cardinal OS — environment variables
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.
# Only the Supabase + App vars are needed for Phase 0; the rest are wired in later
# phases and are listed here so the full surface is documented from day one.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED for Phase 0) ──────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.
# NEXT_PUBLIC_* values are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret. NEVER expose to the browser / commit. Used by server routes
# (admin tasks, webhooks) in later phases.
SUPABASE_SERVICE_ROLE_KEY=

# ── App (REQUIRED for Phase 0) ───────────────────────────────────────────────
# Used to build the OAuth redirect URL. Use http://localhost:3000 locally.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cardinal OS

# ── SEO (optional) ───────────────────────────────────────────────────────────
# Canonical production URL for metadata/sitemap/robots. Defaults to the live
# domain if unset. Set this in Vercel to your production domain.
NEXT_PUBLIC_SITE_URL=https://cardinalos.graviq.in
# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Renders a <meta name="google-site-verification">.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Native app — Google sign-in (Android) ───────────────────────────────────
# The Google **Web** OAuth client id (…apps.googleusercontent.com). The native
# Google credential picker uses it as the serverClientId; its value is the token
# audience Supabase validates, so add the same id to the Supabase Google
# provider's allowed client ids. Safe to expose (NEXT_PUBLIC). Set in Vercel too.
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Native app — Push notifications (FCM, server send) ───────────────────────
# A Firebase service-account JSON (stringified, one line) used by the server to
# send FCM messages. Firebase console → Project settings → Service accounts →
# Generate new private key → paste the whole JSON here. Server-only secret —
# never expose to the browser. The device side instead needs google-services.json
# placed at android/app/google-services.json (gitignored).
FIREBASE_SERVICE_ACCOUNT=
# Gate that turns on in-app push registration. Leave UNSET until google-services.json
# is in the APK build, or the native register() crashes the app. Set to "true" in
# Vercel only after Firebase is configured + the app rebuilt. Safe to expose.
NEXT_PUBLIC_PUSH_ENABLED=

# ── AI (Phase 1+) ────────────────────────────────────────────────────────────
# Use a BILLED / pay-as-you-go Gemini key, never the free-quota key.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Rate limiting ────────────────────────────────────────────────────────────
# Runs in Postgres (supabase/migrations/0003_rate_limit.sql) — no service/keys.

# ── LiveKit — Constellation voice/video rooms ────────────────────────────────
# Leave unset to keep voice rooms dormant (they show a "not enabled" placeholder;
# the shared timer + text chat still work). Works with LiveKit Cloud (free tier,
# no card) or a self-hosted server — same three vars. See docs/livekit.md.
# LIVEKIT_URL is the wss:// signalling URL (ws://localhost:7880 in local dev);
# API key/secret are server-only secrets — never expose to the browser.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Payments — Razorpay (Phase 7) ────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email — Brevo (transactional) ────────────────────────────────────────────
# Used for weekly/monthly review emails and feedback notifications. No-ops when
# unset, so the app still runs locally without email configured.
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Cardinal OS
# Where in-app feedback/reviews are emailed (defaults to the team inbox).
FEEDBACK_NOTIFY_TO=
